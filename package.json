    "@stylistic/eslint-plugin-ts": "^2.9.0",
    "@swc/core": "^1.15.8",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.26",
    "@testing-library/jest-dom": "6.9.1",
