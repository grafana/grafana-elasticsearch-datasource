{
  "name": "elasticsearch",
  "version": "12.6.1",
  "description": "Elasticsearch datasource for Grafana",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "e2e": "playwright test",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "author": "Grafana",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.1.0",
    "@grafana/tsconfig": "2.0.1",
    "@playwright/test": "1.59.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.30",
    "@swc/helpers": "0.5.21",
    "@swc/jest": "0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/lucene": "2.1.7",
    "@types/node": "20.19.27",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/semver": "7.7.1",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.8.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-webpack-plugin": "6.0.0",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "prettier": "3.8.3",
    "react-select-event": "5.5.1",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "semver": "7.7.4",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.7",
    "terser-webpack-plugin": "5.4.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "webpack": "5.105.0",
    "webpack-cli": "7.0.0",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@elastic/esql": "^1.4.1",
    "@elastic/monaco-esql": "^3.2.2",
    "@emotion/css": "11.13.5",
    "@grafana/aws-sdk": "^0.10.0",
    "@grafana/data": "^13.0.0-23250022873",
    "@grafana/i18n": "^12.3.0",
    "@grafana/plugin-ui": "^0.13.1",
    "@grafana/runtime": "^12.3.0",
    "@grafana/schema": "^12.3.0",
    "@grafana/ui": "^12.3.0",
    "@reduxjs/toolkit": "^2.11.2",
    "lucene": "^2.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "packageManager": "npm@11.12.1",
  "overrides": {
    "@grafana/plugin-ui": {
      "@grafana/data": "$@grafana/data"
    }
  }
}
